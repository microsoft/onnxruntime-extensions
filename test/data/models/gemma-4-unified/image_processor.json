{
  "processor": {
    "name": "gemma_4_unified_image_processing",
    "transforms": [
      {
        "operation": {
          "name": "decode_image",
          "type": "DecodeImage",
          "attrs": {
            "color_space": "RGB"
          }
        }
      },
      {
        "operation": {
          "name": "gemma4_image_transform",
          "type": "Gemma4ImageTransform",
          "attrs": {
            "patch_size": 48,
            "max_soft_tokens": 280,
            "pooling_kernel_size": 1
          }
        }
      }
    ]
  }
}
